# ─── Database ────────────────────────────────────────────────────────────────
# Local dev: postgresql://postgres:postgres@localhost:5432/do_app
# Production: get from your managed Postgres provider (Supabase, Neon, Railway)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/do_app"

# ─── NextAuth ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ─── Microsoft (Outlook + Calendar) ──────────────────────────────────────────
# Create app at: https://portal.azure.com → App registrations
# Required API permissions: Mail.Read, Calendars.Read, Tasks.ReadWrite, offline_access
MICROSOFT_CLIENT_ID="your-client-id"
MICROSOFT_CLIENT_SECRET="your-client-secret"
# Use "common" for multi-tenant, or your specific tenant GUID
MICROSOFT_TENANT_ID="common"

# ─── Slack ───────────────────────────────────────────────────────────────────
# Create app at: https://api.slack.com/apps
# Required scopes: openid, profile, email, channels:history, im:history, groups:history
# Redirect URI: http://localhost:3000/api/auth/callback/slack
SLACK_CLIENT_ID="your-slack-client-id"
SLACK_CLIENT_SECRET="your-slack-client-secret"

# ─── Granola ─────────────────────────────────────────────────────────────────
# Webhook secret for validating inbound payloads from Granola
# Set this in the Granola dashboard and match it here
GRANOLA_WEBHOOK_SECRET="your-granola-webhook-secret"

# ─── Anthropic (Claude AI) ───────────────────────────────────────────────────
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-..."
